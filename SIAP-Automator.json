// ==UserScript==
// @name         SIAP Automator - V11.2 (The Precise Striker)
// @namespace    http://tampermonkey.net/
// @version      11.2.0
// @description  Foco total na precisão do clique em checkboxes e rádio botões.
// @match        https://siap.educacao.go.gov.br/*
// @match        https://*.siap.com.br/*
// @match        https://*.siapnet.com.br/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_xmlhttpRequest
// @grant        GM_addStyle
// @connect      pc-do-gon.tailaa9b6a.ts.net
// @connect      *
// @run-at       document-idle
// ==/UserScript==

(function () {
    'use strict';

    if (window.SiapAutomator && window.SiapAutomator.isInitialized) return;
    window.SiapAutomator = { isInitialized: true };

    // --- Estilização Moderna ---
    GM_addStyle(`
        :root {
            --siap-bg: #121218; --siap-card: #1e1e26; --siap-accent: #3b82f6;
            --siap-success: #10b981; --siap-error: #ef4444; --siap-warn: #f59e0b;
            --siap-text: #f3f4f6; --siap-text-dim: #9ca3af; --siap-border: #334155;
        }
        #siap-sidebar {
            position: fixed; top: 0; right: 0; width: 320px; height: 100vh;
            background: var(--siap-bg) !important; color: var(--siap-text) !important;
            z-index: 100000; display: flex; flex-direction: column;
            font-family: 'Inter', 'Segoe UI', sans-serif !important;
            box-shadow: -10px 0 30px rgba(0,0,0,0.5); border-left: 1px solid var(--siap-border) !important;
        }
        .siap-header {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
            padding: 16px 20px; font-weight: bold; display: flex; justify-content: space-between; align-items: center;
        }
        .siap-content { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; overflow-y: auto; }
        .siap-label { font-size: 11px; font-weight: 600; color: var(--siap-text-dim); text-transform: uppercase; margin-bottom: 2px; }
        .siap-input, .siap-textarea {
            width: 100% !important; padding: 10px !important; background: var(--siap-card) !important;
            color: var(--siap-text) !important; border: 1px solid var(--siap-border) !important;
            border-radius: 8px !important; font-size: 13px !important; box-sizing: border-box !important;
        }
        .siap-btn-group { display: flex; gap: 10px; margin-top: 5px; }
        .siap-btn {
            flex: 1; padding: 12px; border: none !important; border-radius: 8px !important;
            cursor: pointer; font-weight: bold; font-size: 13px; display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: all 0.2s; color: white !important;
        }
        #siap-start { background: var(--siap-success) !important; }
        #siap-stop { background: var(--siap-error) !important; }
        #siap-config { background: transparent !important; border: none !important; color: white !important; cursor: pointer; font-size: 18px; }
        #siap-log-output {
            background: #09090b !important; padding: 12px !important; flex: 1; overflow-y: auto;
            font-family: 'Consolas', monospace !important; font-size: 10px !important;
            border-radius: 8px !important; border: 1px solid var(--siap-border) !important;
        }
        #siap-log-output p { margin: 2px 0; border-bottom: 1px solid rgba(255,255,255,0.02); }
    `);

    // --- Lógica Original ---
    const SETTINGS_KEY = 'siap_automator_settings';
    const settings = GM_getValue(SETTINGS_KEY, {
        webhookUrl: 'https://pc-do-gon.tailaa9b6a.ts.net/webhook/siap-automator',
        authToken: 'admingon1'
    });

    const STORAGE_KEY = 'siap_automator_state';
    let stopRequested = false;

    function saveState(data) {
        const existing = GM_getValue(STORAGE_KEY, {});
        const merged = { ...existing, ...data, lastUpdate: Date.now() };
        GM_setValue(STORAGE_KEY, merged);
    }
    function loadState() { return GM_getValue(STORAGE_KEY, {}); }
    function clearState() { GM_setValue(STORAGE_KEY, {}); }

    const logToSidebar = (msg, type = 'info') => {
        const el = document.getElementById('siap-log-output');
        if (!el) return;
        const p = document.createElement('p');
        const colors = { error: '#ff8888', warn: '#ffaa00', success: '#00ff88', info: '#00ccff' };
        p.style.color = colors[type] || colors.info;
        p.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
        el.appendChild(p);
        el.scrollTop = el.scrollHeight;
    };

    const wait = (ms) => new Promise(r => setTimeout(r, ms));
    const fireEvent = (target, eventName) => {
        try { target.dispatchEvent(new MouseEvent(eventName, { bubbles: true, cancelable: true })); } catch (_) {}
    };
    
    const robustClick = async (el) => {
        if (stopRequested) return;
        
        // Tenta achar o checkbox/input real dentro do elemento ou pai
        let target = el.querySelector('input') || (el.tagName === 'INPUT' ? el : null);
        if (!target) {
            const parent = el.parentElement;
            if (parent) target = parent.querySelector('input');
        }
        
        const finalTarget = target || el;
        finalTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
        
        // Destaque visual
        const oldOutline = finalTarget.style.outline;
        finalTarget.style.outline = '4px solid #a855f7';
        await wait(600);
        
        ['mousedown', 'mouseup', 'click'].forEach(name => fireEvent(finalTarget, name));
        if (finalTarget.tagName === 'INPUT') {
            finalTarget.checked = true;
            finalTarget.dispatchEvent(new Event('change', { bubbles: true }));
        }
        
        await wait(400);
        finalTarget.style.outline = oldOutline;
    };

    const typeIntoTextarea = async (el, text) => {
        if (stopRequested) return;
        el.focus();
        await wait(400);
        const nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value')?.set;
        if (nativeSetter) nativeSetter.call(el, text); else el.value = text;
        ['input', 'change', 'blur'].forEach(name => el.dispatchEvent(new Event(name, { bubbles: true })));
    };

    const detectSecao = (text) => {
        const t = text.toLowerCase();
        if (t.includes('metodologia')) return 'metodologias';
        if (t.includes('avalia')) return 'avaliacoes';
        return null;
    };
    const getSectionHeaders = () => {
        return Array.from(document.querySelectorAll('div, td, th, span, label, b, strong, h2, h3, h4, legend'))
            .filter(el => { const t = el.textContent.trim(); return t.length > 3 && t.length < 80 && detectSecao(t) !== null && el.offsetParent !== null; })
            .map(el => ({ el, secao: detectSecao(el.textContent.trim()), y: el.getBoundingClientRect().top + window.scrollY }))
            .sort((a,b) => a.y - b.y);
    };
    const buildTextareaMap = () => {
        const headers = getSectionHeaders();
        const textareas = Array.from(document.querySelectorAll('textarea')).filter(ta => ta.offsetParent !== null)
            .map(ta => ({ el: ta, y: ta.getBoundingClientRect().top + window.scrollY })).sort((a,b) => a.y - b.y);
        const map = {};
        for (const ta of textareas) {
            let closest = null;
            for (const h of headers) { if (h.y < ta.y) closest = h; else break; }
            if (closest && !map[closest.secao]) map[closest.secao] = ta.el;
        }
        return map;
    };

    const getItemsFromDoc = (doc) => {
        let items = [];
        const containers = Array.from(doc.querySelectorAll('div[id*="Nodes"]'));
        containers.forEach(container => {
            Array.from(container.querySelectorAll('span, label, a'))
                .map(el => ({ text: el.textContent.trim(), el }))
                .filter(it => it.text.length > 5)
                .forEach(it => items.push(it));
        });
        return items;
    };

    const collectItems = async () => {
        logToSidebar('Buscando itens...', 'info');
        await wait(2000); // Mais tempo para carregar categorias pesadas
        let all = getItemsFromDoc(document);
        document.querySelectorAll('iframe').forEach(iframe => {
            try { const fd = iframe.contentDocument || iframe.contentWindow.document; all = [...all, ...getItemsFromDoc(fd)]; } catch(_) {}
        });
        const seen = new Set();
        all = all.filter(it => { if(seen.has(it.text)) return false; seen.add(it.text); return true; });
        all.forEach(it => (it.el.style.outline = '1px solid rgba(59,130,246,0.3)'));
        logToSidebar(`${all.length} itens encontrados.`, 'success');
        return all;
    };

    const callWebhook = (data) => {
        return new Promise((resolve, reject) => {
            GM_xmlhttpRequest({
                method: "POST",
                url: settings.webhookUrl,
                data: JSON.stringify(data),
                headers: { "Content-Type": "application/json", "Authorization": `Bearer ${settings.authToken}` },
                onload: (res) => { try { resolve(JSON.parse(res.responseText)); } catch (e) { reject(e); } },
                onerror: (err) => reject(err)
            });
        });
    };

    const normalizeText = (text) => {
        return text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    };

    let isRunning = false;

    const runAutomation = async (isAutoStart = false) => {
        if (isRunning) return;
        stopRequested = false; isRunning = true;
        const btnStart = document.getElementById('siap-start');
        const btnStop = document.getElementById('siap-stop');
        const contextInput = document.getElementById('siap-context').value.trim() || 'Aleatório';
        let qtdTotal = parseInt(document.getElementById('siap-qtd').value) || 1;

        const saved = loadState();
        if (isAutoStart && saved.totalAulas) {
            qtdTotal = saved.totalAulas;
            document.getElementById('siap-qtd').value = qtdTotal;
        }
        
        let aulaAtual = saved.currentAula || 1;
        if (aulaAtual > qtdTotal) {
            logToSidebar(`✅ Concluído.`, 'success');
            isRunning = false; btnStart.disabled = false; btnStop.disabled = true;
            clearState(); return;
        }

        btnStart.disabled = true; btnStop.disabled = false;
        logToSidebar(`▶️ Aula ${aulaAtual} de ${qtdTotal}`, 'info');

        try {
            for (let aula = aulaAtual; aula <= qtdTotal; aula++) {
                if (stopRequested) break;
                const items = await collectItems();
                if (items.length === 0) { logToSidebar('❌ Nenhum item.', 'error'); break; }
                const taMap = buildTextareaMap();

                const blacklist = ['aula', 'avalia', 'projet', 'grup', 'tecnolog', 'debate', 'estudo', 'seminar', 'pesquis', 'contac', 'ludic', 'roda', 'convers', 'brinc', 'jog', 'teatr', 'pati'];
                
                const habs = items.filter(it => it.text.includes('('));
                const objs = items.filter(it => {
                    const norm = normalizeText(it.text);
                    return !it.text.includes('(') && !blacklist.some(r => norm.includes(r));
                });

                logToSidebar(`Habs: ${habs.length} | Objs: ${objs.length}`, 'info');

                const seed = Math.floor(Math.random() * 1000000);
                const prompt = `Professor Especialista. Aula ID: ${seed}. Contexto: ${contextInput}

LISTA A (HABILIDADES):
${habs.map((it, idx) => `A${idx}: ${it.text}`).join('\n')}

LISTA B (CONTEÚDOS):
${objs.map((it, idx) => `B${idx}: ${it.text}`).join('\n')}

REGRAS: Escolha 1 da A e 2 da B. JSON: { "hab_idx": 0, "obj_indices": [0, 1], "metodologia": "...", "avaliacao": "..." }`;

                logToSidebar(`Solicitando IA...`, 'info');
                let parsed;
                try { parsed = await callWebhook({ prompt }); } catch(e) { logToSidebar(`❌ Erro: ${e.message}`, 'error'); break; }
                if (stopRequested) break;

                if (parsed) {
                    if (parsed.hab_idx !== undefined && habs[parsed.hab_idx]) {
                        logToSidebar(`👉 Habilidade: ${habs[parsed.hab_idx].text.substring(0, 30)}...`, 'warn');
                        await robustClick(habs[parsed.hab_idx].el);
                        await wait(1200);
                    }
                    if (parsed.obj_indices && Array.isArray(parsed.obj_indices)) {
                        for (let bIdx of parsed.obj_indices) {
                            if (objs[bIdx]) {
                                logToSidebar(`👉 Conteúdo: ${objs[bIdx].text.substring(0, 30)}...`, 'warn');
                                await robustClick(objs[bIdx].el);
                                await wait(1200);
                            }
                        }
                    }
                    if (taMap['metodologias'] && parsed.metodologia && !stopRequested) await typeIntoTextarea(taMap['metodologias'], parsed.metodologia);
                    if (taMap['avaliacoes'] && parsed.avaliacao && !stopRequested) await typeIntoTextarea(taMap['avaliacoes'], parsed.avaliacao);
                }

                if (stopRequested) break;
                logToSidebar('✅ Aguardando para salvar...', 'warn');
                await wait(4000);
                if (stopRequested) break;

                if (aula < qtdTotal) {
                    saveState({ currentAula: aula + 1, context: contextInput, totalAulas: qtdTotal, isAutoStart: true });
                } else {
                    clearState();
                }

                const botoes = document.querySelectorAll('input[type="submit"], button');
                let btnSalvar = null;
                for (let b of botoes) {
                    if (b.id && b.id.includes('SalvarProximo')) { btnSalvar = b; break; }
                    if (b.value && (b.value.includes('Salvar') || b.value.includes('Próximo'))) { btnSalvar = b; break; }
                }
                if (btnSalvar && !stopRequested) { await robustClick(btnSalvar); return; }
                else { logToSidebar('⏹️ Interrompido.', 'info'); break; }
            }
        } finally {
            isRunning = false; btnStart.disabled = false; btnStop.disabled = true;
        }
    };

    const initSidebar = () => {
        if (document.getElementById('siap-sidebar')) return;
        const saved = loadState();
        const resumeHint = saved.currentAula ? ` (Aula ${saved.currentAula})` : '';

        document.body.insertAdjacentHTML('beforeend', `
            <div id="siap-sidebar">
                <div class="siap-header"><span>🤖 SIAP Automator V11.2</span><button id="siap-config">⚙️</button></div>
                <div class="siap-content">
                    <label class="siap-label">📝 Contexto</label>
                    <textarea id="siap-context" class="siap-textarea" rows="3">${saved.context || ''}</textarea>
                    <label class="siap-label">🔢 Aulas</label>
                    <input type="number" id="siap-qtd" class="siap-input" value="${saved.totalAulas || 1}">
                    <div class="siap-btn-group">
                        <button id="siap-start" class="siap-btn">🚀 Iniciar${resumeHint}</button>
                        <button id="siap-stop" class="siap-btn" disabled>⏹️ Parar</button>
                    </div>
                    <div id="siap-log-output"></div>
                </div>
            </div>
        `);

        document.getElementById('siap-start').addEventListener('click', () => runAutomation(false));
        document.getElementById('siap-stop').addEventListener('click', () => { stopRequested = true; saveState({ isAutoStart: false }); logToSidebar('⏹️ Parando...', 'error'); });
        document.getElementById('siap-config').addEventListener('click', () => {
            const url = prompt("URL Webhook:", settings.webhookUrl);
            const token = prompt("Token:", settings.authToken);
            if (url && token) { settings.webhookUrl = url; settings.authToken = token; GM_setValue(SETTINGS_KEY, settings); location.reload(); }
        });

        if (saved.isAutoStart && saved.currentAula <= saved.totalAulas) {
            logToSidebar(`Retomando aula ${saved.currentAula}...`, 'info');
            setTimeout(() => runAutomation(true), 3000);
        } else {
            logToSidebar('Sistema Pronto.', 'success');
        }
    };

    initSidebar();
})();
